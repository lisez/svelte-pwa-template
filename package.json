{
  "name": "svelte-pwa",
  "version": "1.0.0",
  "description": "TypeScript monorepo template for Svelte PWA",
  "private": true,
  "workspaces": [
    "modules/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @svelte-pwa/app",
    "build": "npm run build -w @svelte-pwa/app",
    "preview": "npm run preview -w @svelte-pwa/app",
    "test": "npm run test -w @svelte-pwa/app",
    "test:watch": "npm run test:watch -w @svelte-pwa/app",
    "test:ui": "npm run test:ui -w @svelte-pwa/app",
    "test:e2e": "npm run test:e2e -w @svelte-pwa/app",
    "test:e2e:ui": "npm run test:e2e:ui -w @svelte-pwa/app",
    "clean": "npm run clean --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.6",
    "@types/node": "^24",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
